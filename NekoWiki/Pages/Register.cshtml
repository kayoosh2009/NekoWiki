@page
@model NekoWiki.Pages.RegisterModel
@{
    ViewData["Title"] = "Registration";

<style>
    /* Глобальные фиксы фона и отступов */
    body {
        background-image: url('https://i.pinimg.com/736x/a0/68/e6/a068e6afda70e3a73e1fa34cb3463029.jpg') !important;
        background-size: cover !important;
        background-repeat: no-repeat !important;
        background-attachment: fixed !important;
        background-position: center !important;
        min-height: 100vh;
        margin: 0;
    }

    /* Обертка, которая не дает форме «схлопнуться» */
    .neko-master-container {
        display: flex;
        justify-content: center;
        align-items: flex-start; /* Прижимаем к верху для прокрутки */
        padding: 60px 20px;
        min-height: 100vh;
        box-sizing: border-box;
    }

    .neko-card {
        background-color: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(10px);
        padding: 35px;
        border-radius: 24px;
        width: 100%;
        max-width: 550px;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.5);
    }

    .neko-header {
        text-align: center;
        margin-bottom: 25px;
    }

    .neko-title {
        color: #5d5750;
        font-weight: 800;
        font-size: 1.8rem;
        margin: 0;
    }

    .neko-subtitle {
        color: #8a8279;
        font-size: 0.9rem;
    }

    /* Сетка для полей */
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .form-group {
        margin-bottom: 12px;
    }

    .form-label {
        display: block;
        font-weight: 700;
        color: #5d5750;
        margin-bottom: 6px;
        font-size: 0.85rem;
    }

    .input-wrapper {
        position: relative;
    }

    .form-control {
        width: 100%;
        height: 45px;
        border-radius: 12px;
        border: 2px solid #e4dcd1;
        padding: 0 15px;
        box-sizing: border-box;
        transition: all 0.2s;
        background: #fdfcfb;
    }

        .form-control:focus {
            border-color: #c9bea6;
            outline: none;
            box-shadow: 0 0 0 4px rgba(228, 220, 209, 0.3);
        }

    /* Иконки глаза и замка */
    .password-toggle {
        position: absolute;
        right: 12px;
        top: 13px;
        width: 20px;
        height: 20px;
        cursor: pointer;
        background-image: url('https://img.icons8.com/?size=100&id=60022&format=png&color=000000');
        background-size: contain;
        background-repeat: no-repeat;
        opacity: 0.4;
    }

        .password-toggle.is-visible {
            background-image: url('https://img.icons8.com/?size=100&id=59825&format=png&color=000000');
            opacity: 0.8;
        }

    .error-message {
        color: #e63946;
        font-size: 0.75rem;
        font-weight: 700;
        margin-top: 4px;
        min-height: 15px;
    }

    .radio-group {
        display: flex;
        gap: 20px;
        margin-top: 5px;
    }

    .form-check {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
        color: #5d5750;
        font-weight: 600;
    }

    .btn-main {
        width: 100%;
        height: 50px;
        background-color: #5d5750;
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        cursor: pointer;
        margin-top: 15px;
        transition: 0.2s;
    }

        .btn-main:hover {
            background-color: #4a453f;
            transform: translateY(-1px);
        }

    .btn-sub {
        width: 100%;
        height: 42px;
        background: transparent;
        border: 2px solid #e4dcd1;
        border-radius: 10px;
        color: #8a8279;
        font-weight: 600;
        cursor: pointer;
        margin-top: 10px;
    }

    .footer-link {
        text-align: center;
        margin-top: 20px;
    }

    .neko-link {
        color: #5d5750;
        font-weight: 700;
        text-decoration: none;
    }

    @@media (max-width: 500px) {
        .form-row {
            grid-template-columns: 1fr;
            gap: 0;
        }
    }
</style>

<div class="neko-master-container">
    <div class="neko-card">
        <div class="neko-header">
            <h2 class="neko-title">Meow Registration 🐾</h2>
            <p class="neko-subtitle">Create your neko-account!</p>
        </div>

        <form id="registerForm" novalidate>
            <div class="form-group">
                <label class="form-label" for="inputLogin">Login</label>
                <div class="input-wrapper">
                    <input type="text" class="form-control" id="inputLogin" placeholder="NekoWarrior77">
                </div>
                <div id="loginHelp" class="error-message"></div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label" for="inputEmail">Email address</label>
                    <input type="email" class="form-control" id="inputEmail" placeholder="meow@mail.com">
                    <div id="emailHelp" class="error-message"></div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="confirmEmail">Confirm Email</label>
                    <input type="email" class="form-control" id="confirmEmail" placeholder="meow@mail.com">
                    <div id="confirmEmailHelp" class="error-message"></div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label" for="inputPassword">Password</label>
                    <div class="input-wrapper">
                        <input type="password" class="form-control input-password" id="inputPassword" placeholder="••••••••">
                        <span id="togglePass" class="password-toggle"></span>
                    </div>
                    <div id="passwordHelp" class="error-message"></div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="confirmPassword">Confirm Password</label>
                    <div class="input-wrapper">
                        <input type="password" class="form-control input-password" id="confirmPassword" placeholder="••••••••">
                        <span id="toggleConfirmPass" class="password-toggle"></span>
                    </div>
                    <div id="confirmPasswordHelp" class="error-message"></div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label" for="inputDOB">Born Date</label>
                    <input type="date" class="form-control" id="inputDOB">
                    <div id="dobHelp" class="error-message"></div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="favCats">What cats do you like?</label>
                    <input type="text" class="form-control" id="favCats" placeholder="Maine Coon...">
                    <div id="favCatsHelp" class="error-message"></div>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Do you love cats?</label>
                <div class="radio-group">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="catLover" id="catLoverYes" value="Yes">
                        <label class="form-check-label" for="catLoverYes">Meow (Yes)</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="catLover" id="catLoverNo" value="No">
                        <label class="form-check-label" for="catLoverNo">No</label>
                    </div>
                </div>
                <div id="catHelp" class="error-message"></div>
            </div>

            <div class="form-check-group">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="checkTerms">
                    <label class="form-check-label" for="checkTerms">I accept meow meow conditions</label>
                </div>
                <div id="termsHelp" class="error-message"></div>
            </div>

            <button type="submit" class="btn-main" id="submitButton">Register</button>
            <button type="button" class="btn-sub" id="resetButton">Reset</button>

            <div class="footer-link">
                <a href="/Login" class="neko-link">Already have an account? Login</a>
            </div>
        </form>
    </div>
</div>

<br />

<script src="~/js/register.js"></script>



}