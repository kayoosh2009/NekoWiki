@page
@model NekoWiki.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="neko-login-container">
    <div class="neko-card">
        <div class="neko-header">
            <h2 class="neko-title">NekoWiki Login 🐾</h2>
            <p class="neko-subtitle">Welcome back, nya!</p>
        </div>

        <form id="loginForm" method="post">
            <div class="form-group">
                <label class="form-label">Username</label>
                <input id="inputUsername" asp-for="Username" class="form-control" placeholder="admin / user1">
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Password</label>
                <div class="input-wrapper">
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••">
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="alert alert-danger p-2" style="font-size: 0.8rem;">
                    @Model.Message
                </div>
            }

            <button type="submit" class="btn-main">Login</button>
        </form>

        <div class="footer-link">
            <span>Don't have an account?</span>
            <a href="/Register">Sign up</a>
        </div>
    </div>
</div>


<link href="~/css/login.css" rel="stylesheet" />
<script src="~/js/login.js"></script>