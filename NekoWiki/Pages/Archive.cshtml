@page
@model NekoWiki.Pages.ArchiveModel
@{
    <style>
        body {
            background-image: url('/img/background.png');
            background-size: 100% auto;
            background-repeat: repeat;
            background-attachment: fixed;
            background-position: center top;
            margin: 0;
            padding: 0;
        }
    </style>

    <div class="container mt-5 pb-5">
        <div class="row row-cols-1 row-cols-md-3 g-4">

            <div class="col">
                <div class="card h-100 shadow">
                    <img src="/img/cats/maine_coon.png" class="card-img-top" alt="Maine Coon" style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <h5 class="card-title">Maine Coon</h5>
                        <p class="card-text">The Maine Coon is one of the largest breeds of domestic cat, known for its majestic appearance, long, fluffy fur, and friendly nature. These cats are often referred to as "gentle giants" due to their impressive size and affectionate nature</p>
                    </div>
                    <div class="card-footer text-center">
                        <a href="/Archive/main_kun" class="btn btn-primary">Read</a>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="card h-100 shadow">
                    <img src="/img/cats/british_shorthair.png" class="card-img-top" alt="British Shorthair" style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <h5 class="card-title">British Shorthair</h5>
                        <p class="card-text">The British Shorthair is one of the most popular breeds, known for its massive build, round head, and thick, "plush" coat. Due to their calm and independent nature, they are often considered ideal companions</p>
                    </div>
                    <div class="card-footer text-center">
                        <a href="/Archive/british_shorthair" class="btn btn-primary">Read</a>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="card h-100 shadow">
                    <img src="/img/cats/siamese.png" class="card-img-top" alt="Siamese Cat" style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <h5 class="card-title">Siamese Cat</h5>
                        <p class="card-text">The Siamese cat is one of the oldest and most recognizable cat breeds, distinguished by its slim, elegant body, distinctive color points, and deep blue, almond-shaped eyes. They are highly intelligent, affectionate, and known for being very vocal.</p>
                    </div>
                    <div class="card-footer text-center">
                        <a href="/Archive/siamese" class="btn btn-primary">Read</a>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="card h-100 shadow">
                    <img src="/img/cats/persian.png" class="card-img-top" alt="Persian Cat" style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <h5 class="card-title">Persian Cat</h5>
                        <p class="card-text">The Persian cat is one of the oldest and most recognized cat breeds, famous for its long, flowing coat, short face, and sweet, docile expression. They are known for their quiet and gentle temperament, making them perfect indoor pets.</p>
                    </div>
                    <div class="card-footer text-center">
                        <a href="/Archive/persian" class="btn btn-primary">Read</a>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="card h-100 shadow">
                    <img src="/img/cats/ragdoll.png" class="card-img-top" alt="Ragdoll Cat" style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <h5 class="card-title">Ragdoll Cat</h5>
                        <p class="card-text">The Ragdoll is a large, semi-longhaired cat breed famous for its striking blue eyes and tendency to completely relax and go limp like a rag doll when held (hence the name). They are known for their gentle, dog-like temperament.</p>
                    </div>
                    <div class="card-footer text-center">
                        <a href="/Archive/ragdoll" class="btn btn-primary">Read</a>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="card h-100 shadow">
                    <img src="/img/cats/bengal.png" class="card-img-top" alt="Bengal Cat" style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <h5 class="card-title">Bengal Cat</h5>
                        <p class="card-text">The Bengal is a hybrid cat breed created from a cross between an Asian Leopard Cat and a domestic cat. They are highly energetic, athletic, and known for their distinctive, wild-looking coat patterns (spotted or marbled).</p>
                    </div>
                    <div class="card-footer text-center">
                        <a href="/Archive/bengal" class="btn btn-primary">Read</a>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <br /> <br />
}